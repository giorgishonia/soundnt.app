# ============================================================================
# soundnt.app — environment configuration
# Copy to .env.local for local dev. NEVER commit real secrets.
# ============================================================================

# --- Database (Supabase Postgres) ---
# Create a project at supabase.com, run supabase/schema.sql in the SQL editor,
# then paste the TRANSACTION POOLER connection string (port 6543 — built for
# serverless). The app's postgres.js client uses prepare:false for this pooler.
# See supabase/README.md.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Optional: the DIRECT connection (port 5432) — only for drizzle-kit migrations
# (`npm run db:migrate`). The transaction pooler above can't run migrations.
# DIRECT_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# --- License signing key (THE CROWN JEWEL — server only) ---
# Ed25519 private JWK as a single-line JSON string. Generate with: npm run keygen
# The public `x` value must be embedded in the desktop app (src-tauri/src/license.rs
# as LICENSE_PUBKEY_B64) and shipped BEFORE this backend goes live.
LICENSE_SIGNING_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"...","d":"..."}

# --- Payments: NOWPayments (primary) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=soundn't <pro@soundnt.app>
SUPPORT_EMAIL=support@soundnt.app

# --- Admin dashboard ---
# Long random string. Sent as `Authorization: Bearer <ADMIN_TOKEN>`.
ADMIN_TOKEN=

# Secret URL slug the ops/admin dashboard is served at (defense-in-depth on TOP
# of ADMIN_TOKEN, not a replacement). Set it to a long random slug, e.g.
# `a9f3k7q2x8`: the panel is then reachable ONLY at `/a9f3k7q2x8`, while the
# obvious `/admin` (and the internal `/ops-panel`) always return 404.
#   * FAIL-CLOSED: if unset, the panel is DISABLED (every path 404s) — nothing is
#     parked at the guessable `/admin`. You must set this to use the dashboard.
#   * Use dot-free, URL-safe characters only (letters/digits/hyphens). A slug with
#     a `.` is rejected (the route matcher skips dotted paths). Matching is
#     case-insensitive.
#   * Baked into the edge bundle at BUILD time — changing it needs a REDEPLOY to
#     take effect (an env-only change + restart won't rotate it).
ADMIN_PATH=

# --- Account magic links ---
# Secret for signing stateless magic-link tokens. If unset, a SEPARATE one-way
# key is derived from ADMIN_TOKEN (the two secrets are never equal). Set a
# dedicated value in production for clean key separation.
ACCOUNT_LINK_SECRET=

# --- Rate limiting / idempotency (Upstash Redis) ---
# Optional in dev — when unset, rate limiting no-ops (allow-all) with a warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App config ---
# Public base URL of this site (used to build success/cancel/IPN callback URLs).
APP_BASE_URL=https://soundnt-app.vercel.app
NEXT_PUBLIC_APP_BASE_URL=https://soundnt-app.vercel.app
MAX_DEVICES=3
PENDING_ORDER_TTL_SECONDS=7200

# --- Optional alternate payment providers ---
BTCPAY_HOST=
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- Test / ops escape hatch ---
# When "true", enables the admin TEST_MODE action that marks an order paid
# without a real payment (mint without spending crypto). NEVER set in prod.
ALLOW_TEST_MODE=false

# --- DEMO MODE (simulated crypto payments — no real money) ---
# When "true":
#   * the "demo" payment provider becomes the active provider (no NOWPayments
#     keys required), so checkout sends buyers to an internal /buy/demo-pay page;
#   * POST /api/demo/pay becomes available (no admin token) to simulate a paid
#     order and mint a real, signed license.
# This GIVES AWAY Pro for free. NEVER set true on a real store.
DEMO_MODE=true
